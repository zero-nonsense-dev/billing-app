
# Dependencies
/node_modules

# Builds — ignore all dist output except the committed Action bundle
/dist/*
# Exception: Action bundle must be committed so GitHub Actions can run it
# directly from the repo tree without a build step.
!/dist/action.cjs
/*.tgz

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store

# Runtime data
/data/

# Secrets
.env
.env.*
